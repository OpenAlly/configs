{
  "name": "@openally/config.eslint",
  "version": "2.4.2",
  "description": "OpenAlly ESLint configuration for Node.js and TypeScript",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test-only": "node --test ./test/**/*.test.ts",
    "test": "c8 --all --src ./src -r html npm run test-only",
    "lint": "eslint src/**/*.ts",
    "sync": "node ./scripts/sync.ts"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenAlly/configs",
    "directory": "src/eslint"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "openally",
    "eslint",
    "eslint-config"
  ],
  "author": "GENTILHOMME Thomas <gentilhomme.thomas@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.2.2",
    "@typescript-eslint/rule-tester": "^8.22.0",
    "@typescript-eslint/utils": "^8.22.0",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "is-core-module": "^2.16.1",
    "typescript-eslint": "^8.19.0"
  },
  "devDependencies": {
    "@openally/httpie": "^1.0.0",
    "@types/jsdom": "^28.0.0",
    "@typescript-eslint/types": "^8.19.0",
    "jsdom": "^28.1.0"
  }
}
